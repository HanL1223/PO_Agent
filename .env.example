
# --- Anthropic (Required) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- LLM Configuration ---
LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# --- Embedding Model ---
# Uses local HuggingFace model (no API key needed)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# --- Jira Integration ---
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_SPACES=CSCI,EDP

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_PREFIX=jira

# --- RAG Settings ---
RAG_TOP_K=5
RAG_CHUNK_SIZE=1024
RAG_CHUNK_OVERLAP=128
RAG_RRF_K=60
RAG_DENSE_WEIGHT=0.6
RAG_SPARSE_WEIGHT=0.4

# --- Cache ---
CACHE_BACKEND=disk
CACHE_TTL_SECONDS=3600
CACHE_DISK_DIR=./data/cache

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_ENV=development
SERVER_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Feature Flags ---
ENABLE_HYBRID_RETRIEVAL=true
ENABLE_CACHE=true
ENABLE_EVALUATION=false
